{
	"name": "frontend",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "react-router dev --host 0.0.0.0",
		"build": "react-router build",
		"start": "react-router-serve build/server/index.js",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "pnpm lint:fix",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:chromium": "playwright test --project=chromium",
		"test:e2e:all": "playwright test",
		"test:e2e:lint": "node scripts/check-e2e-anti-flake.mjs",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install": "playwright install --with-deps chromium",
		"playwright:cli": "npx -y @playwright/cli@latest",
		"typecheck": "tsc --noEmit",
		"check:bundle-budget": "node scripts/check-bundle-budget.mjs",
		"build:ci": "pnpm build && pnpm check:bundle-budget",
		"generate:api": "node scripts/generate-api.js"
	},
	"dependencies": {
		"@base-ui/react": "1.5.0",
		"@fontsource-variable/geist": "5.2.8",
		"@react-router/node": "7.15.1",
		"@react-router/serve": "7.15.1",
		"@tanstack/react-query": "5.100.1",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"i18next": "26.0.8",
		"i18next-browser-languagedetector": "8.2.1",
		"isbot": "5",
		"lucide-react": "1.11.0",
		"next-themes": "0.4.6",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-i18next": "17.0.4",
		"react-router": "7.15.1",
		"shadcn": "4.8.0",
		"tailwind-merge": "3.5.0",
		"tw-animate-css": "1.4.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@playwright/test": "1.59.1",
		"@react-router/dev": "7.15.1",
		"@tailwindcss/vite": "4.2.4",
		"@tanstack/react-query-devtools": "5.100.1",
		"@types/node": "24.10.0",
		"@types/react": "19.2.2",
		"@types/react-dom": "19.2.2",
		"@typescript-eslint/eslint-plugin": "8.59.4",
		"@typescript-eslint/parser": "8.59.4",
		"eslint": "9.39.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "4.4.4",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-prettier": "5.5.5",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"globals": "16.4.0",
		"openapi-typescript": "7.13.0",
		"prettier": "3.8.3",
		"tailwindcss": "4.2.4",
		"typescript": "6.0.3",
		"vite": "7.1.12",
		"vitest": "4.0.7"
	}
}
