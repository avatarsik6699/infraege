# Production backups. Keep RESTIC_PASSWORD_FILE outside git with 600 permissions.
RESTIC_REPOSITORY=/var/backups/template-app/restic
RESTIC_PASSWORD_FILE=/etc/template-app/restic-password
# Commercial production should use S3-compatible off-site storage, for example:
# RESTIC_REPOSITORY=s3:https://storage.yandexcloud.net/my-backup-bucket/template-app/restic
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ru-central1
BACKUP_REDIS=false
BACKUP_VOLUMES=
BACKUP_STATUS_DIR=var/backup-status
BACKUP_MAX_AGE_HOURS=36
BACKUP_HEARTBEAT_URL=
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6
